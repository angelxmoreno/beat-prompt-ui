{
    "name": "beat-prompt-ui",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "prepare": "bun lefthook install",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "check:types": "tsc --noEmit",
        "check:dups": "bun run check:jsinspect && bun run check:jscpd",
        "check:jsinspect": "jsinspect -t 50 --ignore \"node_modules|dist|supabase|docs|tests\" ./src",
        "check:jscpd": "jscpd --config=./jscpd.json ./src",
        "test": "bun test",
        "test:coverage": "bun test --coverage --coverage-reporter=lcov",
        "check": "bun run check:types && bun run lint && bun run check:dups",
        "dev": "vite",
        "build": "tsc -b && vite build",
        "preview": "vite preview"
    },
    "dependencies": {
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.12",
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@types/node": "^24.12.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "globals": "^17.4.0",
        "jscpd": "^4.0.9",
        "lefthook": "^2.1.6",
        "typescript": "~6.0.2",
        "vite": "^8.0.4"
    }
}
